{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "vtmtools",
  "version": "0.4.0",
  "identifier": "com.vtmtools.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "vtmtools",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/Hampternt/vtmtools/releases/latest/download/latest.json"
      ],
      "dialog": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEFGMTNEMzZGMkYzNjRFMUUKUldRZVRqWXZiOU1Ucis1YzZ5ei9RUnU2d2o0SnNINVFOWjhOOSsrcXhKOFVpMVJ4am1uRGNKODEK"
    }
  }
}
